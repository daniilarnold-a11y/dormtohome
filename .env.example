# Server
PORT=3000
NODE_ENV=production

# Security — change this to a long random string before deploying!
JWT_SECRET=change-me-to-something-long-and-random-before-deploying

# Database — path where SQLite file is stored
# On Railway/Render use a mounted volume, e.g. /data/dormtohome.db
DB_PATH=./data/dormtohome.db
